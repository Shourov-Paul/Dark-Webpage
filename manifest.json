{
  "manifest_version": 3,
  "name": "Dark Webpage",
  "version": "1.1",
  "description": "A sleek dark mode and brightness controller with an integrated clock.",
  "action": {
    "default_title": "Toggle Dark Webpage"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "scripting",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon.png",
    "48": "icon.png",
    "16": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["styles.css", "icon.png", "icon.svg"],
      "matches": ["<all_urls>"]
    }
  ]
}
